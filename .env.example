# ============================================================================
# dbplayground configuration
# Copy this file to `.env` (make init) and change ports freely to avoid
# collisions with locally installed or other-container databases.
# ============================================================================

# --- Host ports (host side only; container ports are fixed) ---------------
PG_PORT=15432
MYSQL_PORT=13306
MARIADB_PORT=13307
CLICKHOUSE_HTTP_PORT=18123
CLICKHOUSE_NATIVE_PORT=19000
LDAP_PORT=13389
LDAPS_PORT=16636

# --- Shared SQL identity (Postgres / MySQL / MariaDB) ---------------------
DB_NAME=testdb
DB_USER=playground
DB_PASSWORD=playground
DB_ROOT_PASSWORD=rootpw

# --- ClickHouse -----------------------------------------------------------
CLICKHOUSE_DB=testdb
CLICKHOUSE_USER=playground
CLICKHOUSE_PASSWORD=playground

# --- OpenLDAP (osixia/openldap; profile "ldap") ---------------------------
# Base DN is derived from LDAP_DOMAIN: example.org -> dc=example,dc=org
# NOTE: LDAP_DOMAIN is load-bearing - it is also baked into the base DNs in
# seeds/ldap/01-seed.ldif. If you change it, update that LDIF to match or
# LDAP seeding will fail.
LDAP_ORGANISATION=dbplayground
LDAP_DOMAIN=example.org
LDAP_ADMIN_PASSWORD=adminpw
